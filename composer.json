{
    "name": "paulmann/consensus-ai",
    "description": "A PHP-based consensus decision-making platform inspired by OpenCorum principles",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "ext-pdo": "*",
        "ext-json": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.8"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse src --level=max",
        "lint": "phpcs --standard=PSR12 src",
        "db:init": "php -r \"require 'vendor/autoload.php'; App\\Infrastructure\\Database\\DatabaseTables::createAll(App\\Infrastructure\\Database\\DatabaseConnection::getInstance()->getPdo());\""
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
