# Consensus-AI Environment Configuration
# Copy this file to .env and fill in your values

# Application Settings
APP_NAME="Consensus AI"
APP_ENV=development
APP_DEBUG=1
APP_URL=http://localhost:8080
APP_TIMEZONE=UTC
APP_LOCALE=en

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=consensus_ai
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Logging
LOG_PATH=logs
LOG_LEVEL=debug

# Session Configuration
SESSION_LIFETIME=120
SESSION_SECURE=false

# Cache Configuration
CACHE_DRIVER=file
CACHE_PREFIX=consensus_ai

# Memory Configuration
MEMORY_RETENTION_DAYS=30
MEMORY_MAX_ITEMS_PER_SESSION=500

# AI Model Configuration (for future integration)
AI_MODEL=claude-3-sonnet
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2048

# Rate Limiting
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60
